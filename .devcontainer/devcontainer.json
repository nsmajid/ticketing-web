{
    "name": "Ticketing Web",

    "dockerComposeFile": "../compose.yaml",

    "service": "frontend",

    "workspaceFolder": "/app",

    "shutdownAction": "stopCompose",

    "customizations": {
        "vscode": {
            "extensions": [
                "Vue.volar",
                "Vue.vscode-typescript-vue-plugin",
                "dbaeumer.vscode-eslint",
                "esbenp.prettier-vscode",
                "bradlc.vscode-tailwindcss",
                "eamodio.gitlens"
            ]
        }
    }
}